// synopsys translate_on

// Location: LCCOMB_X1_Y61_N0
cycloneive_lcell_comb \inst2~0 (
// Equation(s):
// \inst2~0_combout  = \inst2~q  $ (\T~input_o )

	.dataa(gnd),
	.datab(gnd),
