// synopsys translate_on

// Location: LCCOMB_X38_Y72_N2
cycloneive_lcell_comb \inst3~1 (
// Equation(s):
// \inst3~1_combout  = (\En~input_o  & ((!\D~input_o ))) # (!\En~input_o  & (\inst3~1_combout ))

	.dataa(gnd),
