wire gnd;
wire vcc;
wire unknown;

assign gnd = 1'b0;
assign vcc = 1'b1;
assign unknown = 1'bx;

tri1 devclrn;
tri1 devpor;
tri1 devoe;
wire \Q~output_o ;
wire \notQ~output_o ;
wire \D~input_o ;
wire \En~input_o ;
wire \inst3~1_combout ;
